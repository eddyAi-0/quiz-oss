GROQ_API_KEY=your_groq_key_here
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# JWT secret per verificare i token Supabase server-side su /api/groq
# Trovalo su: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Upstash Redis — rate limiting 30 req/IP/ora su /api/groq
# Crea un DB su https://console.upstash.com e copia le credenziali REST
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here
